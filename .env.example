# ── Supabase ───────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Project Settings → API). While these are empty, JaaiNgan runs in
# demo mode (mock Google login + data stored in the browser).

# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret — bypasses Row Level Security.
# NEVER prefix with NEXT_PUBLIC_ and never reference it in client components.
SUPABASE_SERVICE_ROLE_KEY=

# ── LINE (optional) ────────────────────────────────────────────────────
# Set this to show "เข้าสู่ระบบด้วย LINE" + account-linking. From a LINE Login
# channel (LINE Developers Console).
NEXT_PUBLIC_LINE_LOGIN_CHANNEL_ID=
#
# These two are NOT app env vars — set them as Supabase Edge Function secrets:
#   supabase secrets set LINE_LOGIN_CHANNEL_SECRET=...      (for line-auth)
#   supabase secrets set LINE_CHANNEL_ACCESS_TOKEN=...      (for line-send, Messaging API)
# then: supabase functions deploy line-auth line-send
