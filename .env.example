# ── Supabase ───────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values from your Supabase
# project (Project Settings → API). While these are empty, JaaiNgan runs in
# demo mode (mock Google login + data stored in the browser).

# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret — bypasses Row Level Security.
# NEVER prefix with NEXT_PUBLIC_ and never reference it in client components.
SUPABASE_SERVICE_ROLE_KEY=

# ── LINE (optional) ────────────────────────────────────────────────────
# Set this to show "เข้าสู่ระบบด้วย LINE" + account-linking. From a LINE Login
# channel (LINE Developers Console).
NEXT_PUBLIC_LINE_LOGIN_CHANNEL_ID=
#
# These two are NOT app env vars — set them as Supabase Edge Function secrets:
#   supabase secrets set LINE_LOGIN_CHANNEL_SECRET=...      (for line-auth)
#   supabase secrets set LINE_CHANNEL_ACCESS_TOKEN=...      (for line-send, Messaging API)
# then: supabase functions deploy line-auth line-send

# ── Web Push (optional) ────────────────────────────────────────────────
# Set this to show the "แจ้งเตือนแบบ Push" toggle in the profile dialog.
# Generate a keypair once:  npx web-push generate-vapid-keys
# Use the PUBLIC key here (it is safe to expose to the browser).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
#
# The PRIVATE key is NOT an app env var — set it (plus the same public key)
# as Supabase Edge Function secrets for the `web-push` function:
#   supabase secrets set VAPID_PUBLIC_KEY=...  VAPID_PRIVATE_KEY=...
#   supabase secrets set VAPID_SUBJECT=mailto:you@example.com
#   supabase secrets set CRON_SECRET=<random>     (shared secret to invoke it)
# then: supabase functions deploy web-push --no-verify-jwt
# (also run `supabase db push` to create the push_subscriptions table)
